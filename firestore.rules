rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Rules for Transactions collection
    match /transactions/{transactionId} {
      // Allow read/update/delete if the document's userId matches the authenticated user
      allow read, update, delete: if isOwner(resource.data.userId);
      
      // Allow create if the user is authenticated and is assigning their own uid as userId
      allow create: if isOwner(request.resource.data.userId);
    }
    
    // Rules for Fixed Expenses collection
    match /fixedExpenses/{expenseId} {
      // Allow read/update/delete if the document's userId matches the authenticated user
      allow read, update, delete: if isOwner(resource.data.userId);
      
      // Allow create if the user is authenticated and is assigning their own uid as userId
      allow create: if isOwner(request.resource.data.userId);
    }
  }
}
