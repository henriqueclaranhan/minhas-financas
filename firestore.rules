rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function validDate(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function validOptionalString(data, field, maxLength) {
      return !(field in data) || (data[field] is string && data[field].size() > 0 && data[field].size() <= maxLength);
    }

    function fieldUnchanged(before, after, field) {
      return before.get(field, null) == after.get(field, null);
    }

    function validTransaction(data) {
      return data.keys().hasAll(['description', 'amount', 'paymentMethod', 'installments', 'date'])
        && data.keys().hasOnly([
          'description', 'amount', 'paymentMethod', 'installments', 'date', 'type',
          'plannedExpenseId', 'category', 'sourceKey'
        ])
        && data.description is string && data.description.size() > 0 && data.description.size() <= 200
        && data.amount is number && data.amount > 0
        && data.paymentMethod in ['credit', 'debit', 'pix', 'cash', 'transfer', 'boleto']
        && data.installments is int && data.installments >= 1 && data.installments <= 360
        && validDate(data.date)
        && (!('type' in data) || data.type in ['income', 'expense'])
        && validOptionalString(data, 'plannedExpenseId', 128)
        && validOptionalString(data, 'category', 100)
        && validOptionalString(data, 'sourceKey', 300);
    }

    function validPlannedExpense(data) {
      return data.keys().hasAll([
          'description', 'amount', 'dueDate', 'isRecurring', 'recurrenceInterval', 'status'
        ])
        && data.keys().hasOnly([
          'description', 'amount', 'dueDate', 'isRecurring', 'recurrenceInterval', 'status',
          'userId', 'type', 'paymentMethod', 'installments', 'category', 'sourcePlannedExpenseId',
          'recurrenceDay'
        ])
        && data.description is string && data.description.size() > 0 && data.description.size() <= 200
        && data.amount is number && data.amount > 0
        && validDate(data.dueDate)
        && data.isRecurring is bool
        && data.recurrenceInterval is int && data.recurrenceInterval >= 1 && data.recurrenceInterval <= 120
        && (!('recurrenceDay' in data)
          || (data.recurrenceDay is int && data.recurrenceDay >= 1 && data.recurrenceDay <= 31))
        && data.status in ['pending', 'confirmed', 'cancelled']
        && (!('type' in data) || data.type in ['income', 'expense'])
        && (!('paymentMethod' in data) || data.paymentMethod in ['credit', 'debit', 'pix', 'cash', 'transfer', 'boleto'])
        && (!('installments' in data) || (data.installments is int && data.installments >= 1 && data.installments <= 360))
        && validOptionalString(data, 'userId', 128)
        && validOptionalString(data, 'category', 100)
        && validOptionalString(data, 'sourcePlannedExpenseId', 128);
    }

    function validCompetenceEntry(data) {
      return data.keys().hasAll([
          'transactionId', 'description', 'amount', 'competenceDate', 'originalDate',
          'paymentMethod', 'type', 'installmentNumber', 'totalInstallments'
        ])
        && data.keys().hasOnly([
          'transactionId', 'description', 'amount', 'competenceDate', 'originalDate',
          'paymentMethod', 'type', 'category', 'installmentNumber', 'totalInstallments'
        ])
        && data.transactionId is string && data.transactionId.size() > 0 && data.transactionId.size() <= 128
        && data.description is string && data.description.size() > 0 && data.description.size() <= 200
        && data.amount is number && data.amount > 0
        && validDate(data.competenceDate)
        && validDate(data.originalDate)
        && data.paymentMethod in ['credit', 'debit', 'pix', 'cash', 'transfer', 'boleto']
        && data.type in ['income', 'expense']
        && validOptionalString(data, 'category', 100)
        && data.installmentNumber is int && data.installmentNumber >= 1 && data.installmentNumber <= 360
        && data.totalInstallments is int
        && data.totalInstallments >= data.installmentNumber
        && data.totalInstallments <= 360;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && request.resource.data.keys().hasOnly(['initialBalance', 'financeSchemaVersion', 'financeMigrationCursor'])
        && (!('initialBalance' in request.resource.data)
          || request.resource.data.initialBalance == null
          || request.resource.data.initialBalance is number)
        && (!('financeSchemaVersion' in request.resource.data)
          || (request.resource.data.financeSchemaVersion is int
            && request.resource.data.financeSchemaVersion >= 1
            && request.resource.data.financeSchemaVersion <= 2))
        && (!('financeMigrationCursor' in request.resource.data)
          || request.resource.data.financeMigrationCursor == null
          || (request.resource.data.financeMigrationCursor is string
            && request.resource.data.financeMigrationCursor.size() <= 128));
      allow delete: if false;

      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && validTransaction(request.resource.data);
        allow update: if isOwner(userId)
          && validTransaction(request.resource.data)
          && fieldUnchanged(resource.data, request.resource.data, 'plannedExpenseId')
          && fieldUnchanged(resource.data, request.resource.data, 'sourceKey');
        allow delete: if isOwner(userId);
      }

      match /plannedExpenses/{expenseId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && validPlannedExpense(request.resource.data);
        allow update: if isOwner(userId)
          && validPlannedExpense(request.resource.data)
          && fieldUnchanged(resource.data, request.resource.data, 'sourcePlannedExpenseId')
          && (resource.data.status == 'pending' || request.resource.data.status == resource.data.status);
        allow delete: if isOwner(userId);
      }

      match /competenceEntries/{entryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && validCompetenceEntry(request.resource.data);
        allow update: if isOwner(userId)
          && validCompetenceEntry(request.resource.data)
          && request.resource.data.transactionId == resource.data.transactionId
          && request.resource.data.installmentNumber == resource.data.installmentNumber;
        allow delete: if isOwner(userId);
      }

      match /importJobs/{jobId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.keys().hasAll(['fingerprint', 'status', 'processed', 'total', 'updatedAt'])
          && request.resource.data.keys().hasOnly(['fingerprint', 'status', 'processed', 'total', 'updatedAt', 'error'])
          && request.resource.data.fingerprint is string
          && request.resource.data.fingerprint.size() > 0
          && request.resource.data.fingerprint.size() <= 100
          && request.resource.data.status in ['validated', 'writing', 'completed', 'failed']
          && request.resource.data.processed is int
          && request.resource.data.processed >= 0
          && request.resource.data.total is int
          && request.resource.data.total >= request.resource.data.processed
          && request.resource.data.total <= 50001
          && request.resource.data.updatedAt is string
          && request.resource.data.updatedAt.size() <= 40
          && validOptionalString(request.resource.data, 'error', 500);
        allow delete: if isOwner(userId);
      }
    }
  }
}
